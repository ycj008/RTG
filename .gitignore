# RTG 项目 .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 虚拟环境
.venv/
venv/
ENV/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# 日志和运行时数据
logs/*.log
data/*.db
data/*.db-journal
data/*.json

# 系统文件
.DS_Store
Thumbs.db

# 配置文件（如包含敏感信息）
# config/system.yaml

# 临时文件
*.tmp
*.bak

# 前端内容
node_modules/
fronted/node_modules/
fronted/.npm_cache

# 忽略打包后的可执行文件
*.exe
*.spec